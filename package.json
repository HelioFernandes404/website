    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.0.0",
    "eslint-config-prettier": "^10.1.1",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
