---
import type { BlogPost } from "../../data/posts";
import { posts } from "../../data/posts";
import profile from "../../data/profile.json";
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Props {
  post: BlogPost;
}

export function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as Props;
const site = Astro.site ?? new URL("https://hub.heliosuns404.com");
const homeUrl = new URL("/", site).toString();
const postUrl = new URL(`/blog/${post.slug}`, site).toString();
const imageUrl = new URL(profile.image, site).toString();
const organizationId = `${homeUrl}#organization`;
const sameAs = profile.links
  .map((link) => link.url)
  .filter((url) => /^https?:\/\//.test(url));

const blogPostingJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  description: post.description,
  datePublished: post.date,
  dateModified: post.date,
  url: postUrl,
  mainEntityOfPage: postUrl,
  articleSection: post.category,
  inLanguage: "pt-BR",
  keywords: post.keywords.join(", "),
  image: imageUrl,
  author: {
    "@type": "Person",
    name: profile.name,
    url: homeUrl,
  },
  publisher: { "@id": organizationId },
};

const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": organizationId,
  name: profile.name,
  url: homeUrl,
  logo: {
    "@type": "ImageObject",
    url: imageUrl,
  },
  sameAs,
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: homeUrl,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Writing",
      item: new URL("/blog", site).toString(),
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.title,
      item: postUrl,
    },
  ],
};

const relatedPosts = posts
  .filter((candidate) => candidate.slug !== post.slug)
  .sort((a, b) => {
    if (a.category === post.category && b.category !== post.category) return -1;
    if (a.category !== post.category && b.category === post.category) return 1;
    return b.date.localeCompare(a.date);
  })
  .slice(0, 3);
---

<BaseLayout
  title={`${post.title} | Helio Fernandes`}
  description={post.description}
  canonicalPath={`/blog/${post.slug}`}
  currentPath="/blog"
  image={profile.image}
  imageAlt={post.title}
  lang="pt-BR"
  ogType="article"
  publishedTime={post.date}
  modifiedTime={post.date}
  jsonLd={[organizationJsonLd, blogPostingJsonLd, breadcrumbJsonLd]}
>
  <article class="post-layout">
    <a class="text-link" href="/blog">← Back to blog</a>

    <header class="post-header">
      <h1>{post.title}</h1>
      <time class="entry-meta" datetime={post.date}>
        {post.date}
      </time>
      <p class="intro-paragraph">{post.lead}</p>
    </header>

    {
      post.sections.map((section) => (
        <section class="post-section">
          <h2>{section.heading}</h2>

          {section.paragraphs.map((paragraph) => <p class="intro-paragraph">{paragraph}</p>)}

          {section.bullets && (
            <ul class="post-bullets">
              {section.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          )}

          {section.tips?.map((tip) => (
            <div class="tip-box">
              <span class="tip-label">Tip</span>
              <p>{tip}</p>
            </div>
          ))}
        </section>
      ))
    }

    <section class="post-section">
      <h2>Checklist final</h2>
      <ul class="post-bullets">
        {post.checklist.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="post-section">
      <h2>Erros comuns</h2>
      <ul class="post-bullets">
        {post.commonErrors.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="post-section">
      <h2>Keywords</h2>
      <ul class="keyword-list">
        {post.keywords.map((keyword) => <li class="keyword-chip">{keyword}</li>)}
      </ul>
    </section>

    {relatedPosts.length > 0 && (
      <section class="post-section">
        <h2>Related reading</h2>
        <ul class="entry-list">
          {relatedPosts.map((relatedPost) => (
            <li>
              <a class="entry-link" href={`/blog/${relatedPost.slug}`}>
                <span class="entry-top">
                  <span class="entry-title-wrap">
                    <span class="entry-title">{relatedPost.title}</span>
                  </span>
                  <span class="entry-tag">{relatedPost.category}</span>
                </span>
                <span class="entry-description">{relatedPost.description}</span>
                <span class="entry-meta">
                  <time datetime={relatedPost.date}>{relatedPost.date}</time> • {relatedPost.category}
                </span>
              </a>
            </li>
          ))}
        </ul>
        <a class="text-link" href="/blog">
          View all posts
        </a>
      </section>
    )}
  </article>
</BaseLayout>
