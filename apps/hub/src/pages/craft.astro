---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Craft | Helio Fernandes";
const description =
  "COGCS: projeto de estudo em transicao para open source para explorar repeticao espacada, aprendizado ativo e documentacao publica.";
const site = Astro.site ?? new URL("https://hub.heliosuns404.com");
const craftUrl = new URL("/craft", site).toString();
const cogcsRepoUrl = "https://github.com/HelioFernandes404/cogcs";
const cogcsCaseUrl = "https://heliosuns404.com/case-studies/cogcs-open-source-learning-project/";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${craftUrl}#webpage`,
  name: title,
  url: craftUrl,
  description,
  inLanguage: "pt-BR",
  mainEntity: {
    "@type": "CreativeWork",
    name: "COGCS",
    url: cogcsCaseUrl,
    description:
      "Learning project that is opening up into open source to explore spaced repetition, active learning and product discovery in public.",
  },
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/craft"
  currentPath="/craft"
  lang="pt-BR"
  jsonLd={jsonLd}
>
  <section class="intro-block">
    <h1>Craft</h1>
    <p class="intro-subtitle">Projetos em abertura para open source e experimentos em construcao.</p>
  </section>

  <section class="content-block">
    <h2>COGCS</h2>

    <ul class="entry-list">
      <li>
        <a
          class="entry-link"
          href={cogcsRepoUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Search for the COGCS repository on GitHub"
        >
          <span class="entry-top">
            <span class="entry-title-wrap">
              <span class="entry-title">GitHub</span>
            </span>
            <span class="entry-tag">Repository</span>
          </span>
          <span class="entry-description">Ver o repositorio publico e acompanhar a evolucao do codigo.</span>
          <span class="entry-meta">Codigo • GitHub • Documentacao</span>
        </a>
      </li>
      <li>
        <a
          class="entry-link"
          href={cogcsCaseUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open the COGCS case study"
        >
          <span class="entry-top">
            <span class="entry-title-wrap">
              <span class="entry-title">Case Study</span>
            </span>
            <span class="entry-tag">Contexto</span>
          </span>
          <span class="entry-description">Problema, escopo, impacto e aprendizados do projeto.</span>
          <span class="entry-meta">Problema real • Escopo pequeno • Aprendizado publico</span>
        </a>
      </li>
    </ul>

    <p class="intro-paragraph">
      Cogcs e um projeto de estudo em transicao para open source. Ele nasceu de uma dor real no meu processo de
      aprendizado e virou um laboratorio para explorar repeticao espacada, UX e decisoes de
      produto em publico.
    </p>
    <p class="intro-paragraph">
      A ideia nao e operar um SaaS paralelo. A proposta e manter um projeto enxuto, documentado e
      util para estudar o problema, medir o que faz sentido e compartilhar o que aprendi.
    </p>
  </section>
</BaseLayout>
