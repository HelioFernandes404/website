---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  currentPath?: string;
  image?: string;
  imageAlt?: string;
  lang?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  canonicalPath = "/",
  currentPath = "/",
  image = "/helio_v2.png",
  imageAlt = title,
  lang = "en",
  ogType = "website",
  publishedTime,
  modifiedTime,
  noindex = false,
  jsonLd,
} = Astro.props;

const site = Astro.site ?? new URL("https://hub.heliosuns404.com");
const canonicalUrl = new URL(canonicalPath, site).toString();
const socialImage = new URL(image, site).toString();
const robotsContent = noindex
  ? "noindex,nofollow,max-image-preview:large"
  : "index,follow,max-image-preview:large";
const ogLocale = lang.includes("-") ? lang.replace("-", "_") : lang;
const jsonLdEntries = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

const navItems = [
  { label: "Index", href: "/" },
  { label: "Craft", href: "/craft" },
  { label: "Writing", href: "/blog" },
];

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content="Helio Fernandes" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="Helio Fernandes" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={imageAlt} />
    {ogType === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === "article" && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <meta name="theme-color" content="#FFFFFF" />

    {
      jsonLdEntries.map((entry) => (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
      ))
    }
  </head>
  <body>
    <div class="site-frame">
      <header class="site-header">
        <div class="shell nav-shell">
          <a href="/" class="brand-link">Helio Fernandes</a>

          <div class="nav-actions">
            <nav aria-label="Primary">
              <ul class="nav-list">
                {
                  navItems.map((item) => (
                    <li>
                      <a
                        class:list={["nav-link", { active: isActive(item.href) }]}
                        href={item.href}
                        aria-current={isActive(item.href) ? "page" : undefined}
                      >
                        {item.label}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </nav>
            <a class="cycle-link" href="https://heliosuns404.com" aria-label="Go to Website page">
              Next: Website
            </a>
          </div>
        </div>
      </header>

      <main class="shell page-shell">
        <slot />
      </main>
    </div>
  </body>
</html>
