---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const projects = (await getCollection("projects")).sort((a, b) =>
    a.data.title.localeCompare(b.data.title, "pt-BR"),
);

const title = "Projetos | Hélio Fernandes";
const description =
    "Projetos de engenharia de software, infraestrutura cloud e automacao com foco em performance e confiabilidade.";
const ogImage = "/og-image.webp";
const canonicalUrl = "https://heliosuns404.com/projetos/";
---

<Layout
    title={title}
    description={description}
    ogImage={ogImage}
    canonicalUrl={canonicalUrl}
>
    <main class="min-h-screen">
        <section class="relative overflow-hidden border-b border-gray-100 bg-gray-50/70">
            <div class="absolute -left-24 top-1/2 hidden h-80 w-80 -translate-y-1/2 rounded-full bg-brand-lime/10 blur-3xl lg:block">
            </div>

            <div class="mx-auto max-w-5xl px-6 py-16 md:py-20">
                <span class="flex items-center gap-2 font-mono text-sm uppercase tracking-wider text-brand-gray">
                    <span class="h-px w-8 bg-brand-lime"></span>
                    Portfolio tecnico
                </span>
                <h1 class="mt-4 text-4xl font-display font-bold tracking-tight lg:text-5xl">
                    Projetos
                </h1>
                <p class="mt-4 max-w-2xl text-lg text-gray-600">
                    Selecao de trabalhos em arquitetura, DevOps e
                    desenvolvimento.
                </p>
            </div>
        </section>

        <section class="mx-auto max-w-5xl px-6 py-16 md:py-20">
            {
                projects.length === 0 ? (
                    <p class="rounded-xl border border-gray-200 bg-white p-6 text-gray-600 shadow-sm">
                        Nenhum projeto publicado ainda.
                    </p>
                ) : (
                    <ul class="grid gap-8 md:grid-cols-2">
                        {projects.map((project) => (
                            <li>
                                <article class="group h-full rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-[transform,border-color,box-shadow] duration-300 hover:-translate-y-2 hover:border-brand-lime hover:shadow-xl">
                                    <h2 class="text-2xl font-semibold tracking-tight">
                                        <a
                                            class="hover-trigger transition-colors group-hover:text-black"
                                            href={`/projetos/${project.slug}/`}
                                        >
                                            {project.data.title}
                                        </a>
                                    </h2>
                                    <p class="mt-3 text-gray-600">
                                        {project.data.description}
                                    </p>
                                    <p class="mt-5 font-mono text-xs uppercase tracking-wide text-gray-500">
                                        {project.data.tech.join(" • ")}
                                    </p>
                                    <a
                                        class="hover-trigger mt-6 inline-flex items-center gap-2 rounded-lg border border-gray-200 px-5 py-2.5 font-medium transition-[border-color,background-color,color,transform] duration-300 hover:border-brand-lime hover:bg-gray-50 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand-lime"
                                        href={`/projetos/${project.slug}/`}
                                    >
                                        Ver projeto
                                        <span aria-hidden="true">-></span>
                                    </a>
                                </article>
                            </li>
                        ))}
                    </ul>
                )
            }
        </section>
    </main>
</Layout>
