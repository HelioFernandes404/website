---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const caseStudies = (await getCollection("case-studies")).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const dateFormatter = new Intl.DateTimeFormat("pt-BR", {
    dateStyle: "long",
    timeZone: "UTC",
});

const title = "Case Studies | Hélio Fernandes";
const description =
    "Estudos de caso com contexto, estrategia tecnica, implementacao e resultados mensuraveis.";
const ogImage = "/og-image.webp";
const canonicalUrl = "https://heliosuns404.com/case-studies/";
---

<Layout
    title={title}
    description={description}
    ogImage={ogImage}
    canonicalUrl={canonicalUrl}
>
    <main class="min-h-screen">
        <section class="relative overflow-hidden border-b border-gray-100 bg-gray-50/70">
            <div class="absolute -right-24 top-1/2 hidden h-80 w-80 -translate-y-1/2 rounded-full bg-brand-lime/10 blur-3xl lg:block">
            </div>

            <div class="mx-auto max-w-4xl px-6 py-16 md:py-20">
                <span class="flex items-center gap-2 font-mono text-sm uppercase tracking-wider text-brand-gray">
                    <span class="h-px w-8 bg-brand-lime"></span>
                    Impacto mensuravel
                </span>
                <h1 class="mt-4 text-4xl font-display font-bold tracking-tight lg:text-5xl">
                    Case Studies
                </h1>
                <p class="mt-4 max-w-2xl text-lg text-gray-600">
                    Experiencias de projeto com foco em contexto, impacto tecnico e resultados observaveis.
                </p>
            </div>
        </section>

        <section class="mx-auto max-w-4xl px-6 py-16 md:py-20">
            {
                caseStudies.length === 0 ? (
                    <p class="rounded-xl border border-gray-200 bg-white p-6 text-gray-600 shadow-sm">
                        Nenhum case study publicado ainda.
                    </p>
                ) : (
                    <ul class="space-y-6">
                        {caseStudies.map((item) => (
                            <li>
                                <article class="group rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-[transform,border-color,box-shadow] duration-300 hover:-translate-y-1 hover:border-brand-lime hover:shadow-xl">
                                    <p class="font-mono text-xs uppercase tracking-wide text-gray-500">
                                        {item.data.client} •{" "}
                                        <time datetime={item.data.date.toISOString()}>
                                            {dateFormatter.format(item.data.date)}
                                        </time>
                                    </p>
                                    <h2 class="mt-3 text-2xl font-semibold tracking-tight">
                                        <a
                                            class="hover-trigger transition-colors group-hover:text-black"
                                            href={`/case-studies/${item.slug}/`}
                                        >
                                            {item.data.title}
                                        </a>
                                    </h2>
                                    <p class="mt-3 text-gray-600">{item.data.description}</p>
                                    <a
                                        class="hover-trigger mt-6 inline-flex items-center gap-2 rounded-lg border border-gray-200 px-5 py-2.5 font-medium transition-[border-color,background-color,color,transform] duration-300 hover:border-brand-lime hover:bg-gray-50 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand-lime"
                                        href={`/case-studies/${item.slug}/`}
                                    >
                                        Ver case study
                                        <span aria-hidden="true">-></span>
                                    </a>
                                </article>
                            </li>
                        ))}
                    </ul>
                )
            }
        </section>
    </main>
</Layout>
