---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blog");

    return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

interface Props {
    post: CollectionEntry<"blog">;
}

const { post } = Astro.props as Props;
const { Content } = await post.render();

const dateFormatter = new Intl.DateTimeFormat("pt-BR", {
    dateStyle: "long",
    timeZone: "UTC",
});

const title = `${post.data.title} | Blog`;
const description = post.data.description;
const ogImage = "/og-image.webp";
const canonicalUrl = `https://heliosuns404.com/blog/${post.slug}/`;
---

<Layout
    title={title}
    description={description}
    ogImage={ogImage}
    canonicalUrl={canonicalUrl}
>
    <main class="min-h-screen">
        <section class="border-b border-gray-100 bg-gray-50/70">
            <div class="mx-auto max-w-3xl px-6 py-16 md:py-20">
                <div class="flex flex-wrap items-center gap-3 font-mono text-sm uppercase tracking-wider text-brand-gray">
                    <span>Artigo</span>
                    <span class="rounded-full border border-gray-200 px-2 py-1 text-[11px] text-gray-600">
                        {post.data.category}
                    </span>
                </div>
                <h1 class="mt-3 text-4xl font-display font-bold tracking-tight lg:text-5xl">
                    {post.data.title}
                </h1>
                <p class="mt-4 text-lg text-gray-600">{post.data.lead ?? post.data.description}</p>
                <p class="mt-6 font-mono text-xs uppercase tracking-wide text-gray-500">
                    <time datetime={post.data.pubDate.toISOString()}>
                        {dateFormatter.format(post.data.pubDate)}
                    </time>
                </p>
                {
                    post.data.tags.length > 0 && (
                        <ul class="mt-6 flex flex-wrap gap-2">
                            {post.data.tags.map((tag) => (
                                <li class="rounded-full border border-gray-200 px-3 py-1 text-xs font-medium text-gray-600">
                                    {tag}
                                </li>
                            ))}
                        </ul>
                    )
                }
            </div>
        </section>

        <section class="mx-auto max-w-3xl px-6 py-16 md:py-20">
            <article class="article-content rounded-2xl border border-gray-100 bg-white p-8 shadow-sm md:p-10">
                <Content />
            </article>

            <a
                href="/blog/"
                class="hover-trigger mt-8 inline-flex items-center gap-2 rounded-lg border border-gray-200 px-5 py-2.5 font-medium transition-all duration-300 hover:border-brand-lime hover:bg-gray-50"
            >
                Voltar para blog
                <span aria-hidden="true">&lt;-</span>
            </a>
        </section>
    </main>
</Layout>
