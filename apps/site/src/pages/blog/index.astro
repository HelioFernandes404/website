---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const dateFormatter = new Intl.DateTimeFormat("pt-BR", {
    dateStyle: "long",
    timeZone: "UTC",
});

const title = "Blog | Hélio Fernandes";
const description =
    "Artigos sobre DevOps, infraestrutura escalável, Kubernetes, CI/CD e desenvolvimento de alta performance.";
const ogImage = "/og-image.webp";
const canonicalUrl = "https://heliosuns404.com/blog/";
---

<Layout
    title={title}
    description={description}
    ogImage={ogImage}
    canonicalUrl={canonicalUrl}
>
    <main class="min-h-screen">
        <section class="relative overflow-hidden border-b border-gray-100 bg-gray-50/70">
            <div class="absolute -right-20 top-1/2 hidden h-80 w-80 -translate-y-1/2 rounded-full bg-brand-lime/10 blur-3xl lg:block">
            </div>

            <div class="mx-auto max-w-4xl px-6 py-16 md:py-20">
                <span class="flex items-center gap-2 font-mono text-sm uppercase tracking-wider text-brand-gray">
                    <span class="h-px w-8 bg-brand-lime"></span>
                    Conteudo tecnico
                </span>
                <h1 class="mt-4 text-4xl font-display font-bold tracking-tight lg:text-5xl">
                    Blog
                </h1>
                <p class="mt-4 max-w-2xl text-lg text-gray-500">
                    Conteudos publicados sobre arquitetura, backend e engenharia
                    de plataforma.
                </p>
            </div>
        </section>

        <section class="mx-auto max-w-4xl px-6 py-16 md:py-20">
            {
                posts.length === 0 ? (
                    <p class="rounded-xl border border-gray-200 bg-white p-6 text-gray-600 shadow-sm">
                        Nenhum post publicado ainda.
                    </p>
                ) : (
                    <ul class="space-y-6">
                        {posts.map((post) => (
                            <li>
                                <article class="group rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-[transform,border-color,box-shadow] duration-300 hover:-translate-y-1 hover:border-brand-lime hover:shadow-xl">
                                    <div class="flex flex-wrap items-center gap-3 font-mono text-xs uppercase tracking-wide text-gray-500">
                                        <time datetime={post.data.pubDate.toISOString()}>
                                            {dateFormatter.format(post.data.pubDate)}
                                        </time>
                                        <span class="rounded-full border border-gray-200 px-2 py-1 text-[11px] text-gray-600">
                                            {post.data.category}
                                        </span>
                                    </div>
                                    <h2 class="mt-3 text-2xl font-semibold tracking-tight">
                                        <a
                                            class="hover-trigger transition-colors group-hover:text-black"
                                            href={`/blog/${post.slug}/`}
                                        >
                                            {post.data.title}
                                        </a>
                                    </h2>
                                    {
                                        post.data.lead && (
                                            <p class="mt-3 text-base font-medium text-gray-800">
                                                {post.data.lead}
                                            </p>
                                        )
                                    }
                                    <p class="mt-3 text-gray-600">{post.data.description}</p>
                                    {
                                        post.data.tags.length > 0 && (
                                            <ul class="mt-4 flex flex-wrap gap-2">
                                                {post.data.tags.slice(0, 4).map((tag) => (
                                                    <li class="rounded-full border border-gray-200 px-3 py-1 text-xs font-medium text-gray-600">
                                                        {tag}
                                                    </li>
                                                ))}
                                            </ul>
                                        )
                                    }
                                    <a
                                        class="hover-trigger mt-6 inline-flex items-center gap-2 rounded-lg border border-gray-200 px-5 py-2.5 font-medium transition-[border-color,background-color,color,transform] duration-300 hover:border-brand-lime hover:bg-gray-50 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand-lime"
                                        href={`/blog/${post.slug}/`}
                                    >
                                        Ler artigo
                                        <span aria-hidden="true">-></span>
                                    </a>
                                </article>
                            </li>
                        ))}
                    </ul>
                )
            }
        </section>
    </main>
</Layout>
