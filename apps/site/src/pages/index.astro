---
import Layout from "../layouts/Layout.astro";

const title = "Hélio Fernandes - DevOps Architect";
const description =
    "DevOps Architect especializado em infraestrutura escalável, Kubernetes, CI/CD e desenvolvimento backend de alta performance.";
const ogImage = "/og-image.webp";
const canonicalUrl = "https://heliosuns404.com/";

const services = [
    {
        title: "DevOps Engineering",
        description:
            "Arquitetura resiliente e automacao completa com Kubernetes, Helm e pipelines CI/CD.",
        stack: ["AWS / Azure", "Terraform"],
        badge: "/>",
        highlight: false,
        delayClass: "stagger-delay-1",
    },
    {
        title: "Backend & Data",
        description:
            "Desenvolvimento de APIs robustas e processamento de dados com foco em performance e escalabilidade.",
        stack: ["Python / Node.js", "Data Engineering"],
        badge: "{}",
        highlight: true,
        delayClass: "stagger-delay-2",
    },
    {
        title: "ML & Gen AI Engineer",
        description:
            "Criacao de agentes inteligentes e workflows generativos com engenharia de dados e MLOps.",
        stack: ["LLMs / RAG", "Databricks"],
        badge: "AI",
        highlight: false,
        delayClass: "stagger-delay-3",
    },
];

const featuredProjects = [
    {
        slug: "dai-tec-ai",
        category: "01. Fintech",
        title: "Dai Tec AI",
        description:
            "Implementacao de infraestrutura financeira segura. Integracao de Stripe e OpenAI com ganho de 30% em conversao.",
        tech: ["Stripe", "AWS", "Node.js"],
        image:
            "https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=800&auto=format&fit=crop",
        alt: "Projeto Dai Tec AI com dashboard financeiro e automacao inteligente",
        metricLabel: "IMPACT FACTOR",
        metricValue: "+30%",
        metricCaption: "CONVERSION RATE",
        reverse: false,
        comingSoon: false,
    },
    {
        slug: "systemframe",
        category: "02. Data Ops",
        title: "SystemFrame",
        description:
            "Reestruturacao completa de DevOps com Kubernetes, reduzindo taxa de erros em 30% e acelerando time-to-market.",
        tech: ["K8s", "Helm", "Python"],
        image:
            "https://images.unsplash.com/photo-1558494949-ef010cbdcc31?q=80&w=800&auto=format&fit=crop",
        alt: "Projeto SystemFrame focado em infraestrutura DevOps com Kubernetes",
        metricLabel: "PERFORMANCE",
        metricValue: "-30%",
        metricCaption: "ERROR RATE",
        reverse: true,
        comingSoon: false,
    },
    {
        slug: "cogcs",
        category: "03. Learning Project",
        title: "Cogcs",
        description:
            "Projeto de estudo em transicao para open source, criado para explorar repeticao espacada, aprendizado ativo e decisoes de produto a partir de uma dor real de estudo.",
        tech: ["K3s", "Ansible", "Cloudflare"],
        image:
            "https://images.unsplash.com/photo-1551650975-87deedd944c3?q=80&w=800&auto=format&fit=crop",
        alt: "Projeto Cogcs em transicao para open source para estudar repeticao espacada e arquitetura",
        metricLabel: "STATUS",
        metricValue: "Opening Up",
        metricCaption: "OPEN SOURCE",
        reverse: false,
        comingSoon: false,
    },
];

const testimonials = [
    {
        text: "Tive o prazer de trabalhar com o Helio. O que mais se destaca e a visao estrategica que ele traz para a equipe.",
        author: "Acacio Fernandes",
        role: "Head de Tecnologia",
    },
    {
        text: "Trouxe clareza tecnica para o projeto e desenhou uma base de infraestrutura preparada para escalar com seguranca.",
        author: "Juliana Herane",
        role: "Product Owner",
    },
    {
        text: "Nao entrega so codigo: entrega solucao ponta a ponta, com criterio tecnico e foco no negocio.",
        author: "Andre Dini",
        role: "Tech Lead",
    },
];
---

<Layout
    title={title}
    description={description}
    ogImage={ogImage}
    canonicalUrl={canonicalUrl}
>
    <main class="min-h-screen">
        <section
            class="relative min-h-[90vh] flex items-center justify-center overflow-hidden tech-grid"
        >
            <div
                class="absolute top-1/2 right-0 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-b from-brand-lime/10 to-transparent rounded-full blur-[100px] -z-10 animate-pulse-slow"
            ></div>

            <div
                class="max-w-7xl mx-auto px-6 w-full grid lg:grid-cols-12 gap-12 items-center"
            >
                <div class="lg:col-span-7 space-y-8 z-10">
                    <div
                        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-gray-50 border border-gray-200 text-xs font-mono font-medium text-gray-600 opacity-0 animate-fade-in-up"
                        style="animation-delay: 0.1s"
                    >
                        <span
                            class="w-2 h-2 rounded-full bg-green-500 animate-pulse"
                        ></span>
                        Available for new projects
                    </div>

                    <h1
                        class="text-5xl lg:text-7xl font-display font-bold leading-[0.95] tracking-tight opacity-0 animate-fade-in-up"
                        style="animation-delay: 0.2s"
                    >
                        Código eficiente.<br />
                        Infraestrutura
                        <span class="relative inline-block whitespace-nowrap">
                            <span class="relative z-10">escalável</span>
                            <span
                                class="absolute bottom-2 left-0 w-full h-4 bg-brand-lime/80 -z-0 transform -skew-x-12"
                            ></span>
                        </span>.
                    </h1>

                    <p
                        class="text-xl text-gray-500 max-w-xl leading-relaxed opacity-0 animate-fade-in-up"
                        style="animation-delay: 0.3s"
                    >
                        Sou Hélio Fernandes. Transformo arquiteturas complexas
                        em produtos digitais robustos. Especialista em
                        <strong class="text-black bg-gray-100 px-1"
                            >DevOps</strong
                        >
                        e desenvolvimento de alta performance.
                    </p>

                    <div
                        class="flex flex-wrap gap-4 pt-4 opacity-0 animate-fade-in-up"
                        style="animation-delay: 0.4s"
                    >
                        <a
                            href="mailto:heliodevhub@gmail.com?subject=Contato%20via%20site"
                            class="group relative px-8 py-4 bg-black text-white rounded-lg font-medium overflow-hidden hover-trigger shadow-lg hover:shadow-xl transition-all"
                        >
                            <div
                                class="absolute inset-0 w-full h-full bg-brand-lime transition-all duration-300 translate-y-full group-hover:translate-y-0"
                            ></div>
                            <span
                                class="relative group-hover:text-black transition-colors flex items-center gap-2"
                            >
                                Vamos conversar
                                <span aria-hidden="true">-></span>
                            </span>
                        </a>
                        <a
                            href="#projetos"
                            class="px-8 py-4 rounded-lg border border-gray-200 font-medium hover:bg-gray-50 transition-colors hover-trigger hover:border-gray-400"
                        >
                            Ver Portfolio
                        </a>
                    </div>
                </div>

                <div
                    class="lg:col-span-5 hidden lg:block relative opacity-0 animate-fade-in-up"
                    style="animation-delay: 0.6s"
                >
                    <div class="relative hover-trigger">
                        <div
                            class="relative rounded-2xl overflow-hidden shadow-2xl border-2 border-gray-100 transform transition-transform duration-500 hover:rotate-1 hover:scale-105"
                        >
                            <img
                                src="/sobre.webp"
                                alt="Hélio Fernandes - DevOps Architect especializado em Kubernetes e infraestrutura cloud"
                                class="w-full h-auto object-cover"
                                loading="eager"
                                decoding="async"
                                fetchpriority="high"
                            />
                        </div>

                        <div
                            class="absolute -z-10 -bottom-6 -right-6 w-full h-full border-2 border-brand-lime/20 rounded-2xl"
                        ></div>
                        <div
                            class="absolute -z-20 -top-6 -left-6 w-24 h-24 bg-brand-lime/20 blur-2xl rounded-full"
                        ></div>
                    </div>
                </div>
            </div>

            <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    class="h-6 w-6 text-gray-400"
                    aria-hidden="true"
                >
                    <path d="m6 9 6 6 6-6"></path>
                </svg>
            </div>
        </section>

        <section id="servicos" class="relative overflow-hidden bg-gray-50 py-24">
            <div class="mx-auto max-w-7xl px-6">
                <div class="mb-16 reveal-on-scroll">
                    <span
                        class="flex items-center gap-2 font-mono text-sm uppercase tracking-wider text-brand-gray"
                    >
                        <span class="h-px w-8 bg-brand-lime"></span>
                        Minha Expertise
                    </span>
                    <h2 class="mt-4 text-3xl font-display font-bold lg:text-4xl">
                        Solucoes end-to-end
                    </h2>
                </div>

                <div class="grid gap-6 md:grid-cols-3">
                    {
                        services.map((service) => (
                            <article
                                class:list={[
                                    "group reveal-on-scroll hover-trigger rounded-2xl border p-8 shadow-sm transition-all duration-300 hover:-translate-y-2",
                                    service.highlight
                                        ? "border-gray-800 bg-black text-white hover:shadow-xl"
                                        : "border-gray-100 bg-white hover:border-brand-lime hover:shadow-xl",
                                    service.delayClass,
                                ]}
                            >
                                <div
                                    class:list={[
                                        "mb-6 flex h-12 w-12 items-center justify-center rounded-lg font-mono text-sm font-semibold transition-all duration-300 group-hover:scale-110",
                                        service.highlight
                                            ? "bg-white/10 text-white group-hover:bg-brand-lime group-hover:text-black"
                                            : "bg-gray-50 text-gray-600 group-hover:bg-brand-lime group-hover:text-black",
                                    ]}
                                >
                                    {service.badge}
                                </div>

                                <h3 class="mb-3 text-xl font-display font-bold">
                                    {service.title}
                                </h3>
                                <p
                                    class:list={[
                                        "text-sm leading-relaxed",
                                        service.highlight
                                            ? "text-gray-400"
                                            : "text-gray-500",
                                    ]}
                                >
                                    {service.description}
                                </p>

                                <div
                                    class:list={[
                                        "mt-6 border-t pt-4 opacity-70 transition-opacity group-hover:opacity-100",
                                        service.highlight
                                            ? "border-gray-800"
                                            : "border-gray-100",
                                    ]}
                                >
                                    <ul
                                        class:list={[
                                            "space-y-2 font-mono text-xs",
                                            service.highlight
                                                ? "text-gray-500"
                                                : "text-gray-400",
                                        ]}
                                    >
                                        {service.stack.map((item) => (
                                            <li class="flex items-center gap-2">
                                                <span class="h-1.5 w-1.5 rounded-full bg-brand-lime"></span>
                                                {item}
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                            </article>
                        ))
                    }
                </div>
            </div>
        </section>

        <section
            id="projetos"
            class="relative overflow-hidden bg-brand-black py-24 text-white"
        >
            <div
                class="absolute top-0 right-0 h-full w-1/2 bg-gradient-to-l from-[#111] to-transparent opacity-50 pointer-events-none"
                aria-hidden="true"
            ></div>

            <div class="mx-auto max-w-7xl px-6">
                <div
                    class="mb-20 flex flex-col items-start justify-between gap-6 md:flex-row md:items-end reveal-on-scroll"
                >
                    <div>
                        <span
                            class="flex items-center gap-2 font-mono text-sm uppercase tracking-wider text-brand-lime"
                        >
                            <span class="h-2 w-2 rounded-full bg-brand-lime animate-pulse"></span>
                            Selected Works
                        </span>
                        <h2 class="mt-4 text-4xl font-display font-bold lg:text-6xl">
                            Cases Reais
                        </h2>
                    </div>
                    <p
                        class="max-w-sm border-l border-gray-700 pl-4 text-right text-gray-400 md:text-left"
                    >
                        Projetos onde tecnologia e negocio se encontram para
                        gerar resultados mensuraveis.
                    </p>
                </div>

                <div class="space-y-32">
                    {
                        featuredProjects.map((project) => (
                            <article
                                class="group relative grid items-center gap-12 lg:grid-cols-2 reveal-on-scroll"
                            >
                                <div
                                    class:list={[
                                        "order-2 transition-transform duration-500",
                                        project.reverse
                                            ? "lg:order-2 text-right lg:text-left group-hover:-translate-x-2"
                                            : "lg:order-1 group-hover:translate-x-2",
                                    ]}
                                >
                                    <div class="mb-4 font-mono text-sm text-brand-lime">
                                        {project.category}
                                    </div>
                                    <h3 class="mb-4 text-3xl font-display font-bold">
                                        {project.title}
                                    </h3>
                                    <p class="mb-6 leading-relaxed text-gray-400">
                                        {project.description}
                                    </p>
                                    <div
                                        class:list={[
                                            "mb-8 flex flex-wrap gap-2 font-mono text-xs",
                                            project.reverse
                                                ? "justify-end lg:justify-start"
                                                : "",
                                        ]}
                                    >
                                        {project.tech.map((item) => (
                                            <span
                                                class="cursor-default rounded-full border border-white/10 bg-white/5 px-3 py-1 transition-colors hover:bg-brand-lime hover:text-black"
                                            >
                                                {item}
                                            </span>
                                        ))}
                                    </div>
                                    <a
                                        href={`/projetos/${project.slug}/`}
                                        class="hover-trigger inline-flex items-center gap-2 rounded-lg border border-white/20 px-5 py-2.5 font-medium transition-all duration-300 hover:border-brand-lime hover:bg-brand-lime hover:text-black"
                                    >
                                        Ver caso
                                        <span aria-hidden="true">-></span>
                                    </a>
                                </div>

                                <div
                                    class:list={[
                                        "order-1 relative hover-trigger",
                                        project.reverse ? "lg:order-1" : "lg:order-2",
                                    ]}
                                >
                                    {
                                        project.comingSoon && (
                                            <div class="absolute -top-4 -right-4 z-30 rounded bg-brand-lime px-3 py-1 font-mono text-xs font-bold text-black shadow-[0_0_15px_rgba(204,255,0,0.6)] animate-pulse">
                                                Coming Soon
                                            </div>
                                        )
                                    }

                                    <div
                                        class:list={[
                                            "absolute -inset-2 rounded-xl blur-lg opacity-0 transition-opacity duration-500 group-hover:opacity-30",
                                            project.reverse
                                                ? "bg-gradient-to-l from-brand-lime to-transparent"
                                                : "bg-gradient-to-r from-brand-lime to-transparent",
                                        ]}
                                    ></div>
                                    <div
                                        class="relative aspect-video overflow-hidden rounded-xl border border-gray-800 bg-gray-900 shadow-2xl transition-transform duration-500 group-hover:scale-[1.02]"
                                    >
                                        <div
                                            class="scanlines absolute inset-0 z-10 opacity-30 pointer-events-none"
                                        ></div>
                                        <img
                                            src={project.image}
                                            alt={project.alt}
                                            class="h-full w-full object-cover opacity-60 grayscale transition-all duration-700 group-hover:opacity-100 group-hover:grayscale-0"
                                            loading="lazy"
                                            decoding="async"
                                            fetchpriority="low"
                                            width="800"
                                            height="450"
                                        />

                                        <div
                                            class="absolute inset-0 z-20 flex items-center justify-center bg-black/60 opacity-0 backdrop-blur-sm transition-opacity duration-300 group-hover:opacity-100"
                                        >
                                            <div
                                                class="text-center transform translate-y-8 transition-transform duration-500 ease-out group-hover:translate-y-0"
                                            >
                                                <div
                                                    class="mb-2 inline-block border-b border-brand-lime/30 pb-2 font-mono text-xs tracking-widest text-brand-lime"
                                                >
                                                    {project.metricLabel}
                                                </div>
                                                <div
                                                    class="mb-1 font-display text-4xl font-bold text-white"
                                                >
                                                    {project.metricValue}
                                                </div>
                                                <div class="font-mono text-xs text-gray-400">
                                                    {project.metricCaption}
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </article>
                        ))
                    }
                </div>
            </div>
        </section>

        <section id="depoimentos" class="relative bg-white py-24">
            <div class="mx-auto max-w-6xl px-6">
                <div class="mb-12 text-center reveal-on-scroll">
                    <div
                        class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-full bg-brand-lime/20 text-brand-black"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                            class="h-6 w-6"
                            aria-hidden="true"
                        >
                            <path d="M10 11H6a4 4 0 0 1 4-4"></path>
                            <path d="M18 11h-4a4 4 0 0 1 4-4"></path>
                            <path d="M6 11v2a4 4 0 0 0 4 4"></path>
                            <path d="M14 11v2a4 4 0 0 0 4 4"></path>
                        </svg>
                    </div>
                    <h2 class="text-3xl font-display font-bold lg:text-4xl">
                        Feedback de quem trabalhou comigo
                    </h2>
                </div>

                <div class="grid gap-6 md:grid-cols-3">
                    {
                        testimonials.map((testimonial, index) => (
                            <article
                                class:list={[
                                    "reveal-on-scroll rounded-2xl border border-gray-100 bg-gray-50 p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-brand-lime hover:shadow-lg",
                                    index === 0
                                        ? "stagger-delay-1"
                                        : index === 1
                                          ? "stagger-delay-2"
                                          : "stagger-delay-3",
                                ]}
                            >
                                <p class="mb-8 leading-relaxed text-gray-700">
                                    "{testimonial.text}"
                                </p>
                                <div>
                                    <h3 class="font-semibold text-black">
                                        {testimonial.author}
                                    </h3>
                                    <p class="font-mono text-xs text-gray-500">
                                        {testimonial.role}
                                    </p>
                                </div>
                            </article>
                        ))
                    }
                </div>
            </div>
        </section>
    </main>
</Layout>
