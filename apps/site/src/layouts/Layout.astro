---
import SEOHead from "../components/SEOHead.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  lang?: string;
}

const {
  title,
  description,
  ogImage,
  canonicalUrl,
  lang = "pt-BR",
}: Props = Astro.props;

const pathname = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "/inicio" },
  { href: "/blog/", label: "/blog" },
  { href: "/projetos/", label: "/projetos" },
  { href: "/case-studies/", label: "/case-studies" },
];

const isActiveLink = (href: string) => {
  if (href === "/") {
    return pathname === "/";
  }

  return pathname.startsWith(href);
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ccff00" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@500;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@500;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      canonicalUrl={canonicalUrl}
    />
  </head>
  <body class="selection:bg-brand-lime selection:text-black">
    <div class="noise-overlay"></div>

    <div class="relative flex min-h-screen flex-col">
      <header
        id="main-header"
        class="fixed top-0 z-50 w-full border-b border-transparent bg-white/80 backdrop-blur-md transition-all duration-300"
      >
        <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6">
          <a href="/" class="group flex items-center gap-2 hover-trigger">
            <div
              class="flex h-8 w-8 items-center justify-center rounded-lg bg-black font-display text-sm font-bold text-white transition-colors duration-300 group-hover:bg-brand-lime group-hover:text-black"
            >
              H
            </div>
            <span
              class="font-display text-lg font-bold tracking-tight transition-all duration-300 group-hover:tracking-wide"
            >
              Helio.dev
            </span>
          </a>

          <nav
            class="hidden items-center space-x-10 font-mono text-sm font-medium text-gray-500 md:flex"
          >
            {
              navLinks.map((link) => {
                const active = isActiveLink(link.href);

                return (
                  <a
                    href={link.href}
                    class:list={[
                      "relative group py-2 transition-colors hover:text-black hover-trigger",
                      active && "text-black",
                    ]}
                    aria-current={active ? "page" : undefined}
                  >
                    <span class="relative z-10">{link.label}</span>
                    <span
                      class:list={[
                        "absolute bottom-0 left-0 h-0.5 bg-brand-lime transition-all duration-300",
                        active ? "w-full" : "w-0 group-hover:w-full",
                      ]}
                    ></span>
                  </a>
                );
              })
            }
          </nav>

          <button
            id="mobile-menu-button"
            type="button"
            class="hover-trigger p-2 md:hidden"
            aria-label="Abrir menu"
            aria-controls="mobile-menu"
            aria-expanded="false"
          >
            <span class="sr-only">Abrir menu</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              class="h-6 w-6"
              aria-hidden="true"
            >
              <path d="M4 7h16M4 12h16M4 17h16"></path>
            </svg>
          </button>
        </div>

        <div
          id="mobile-menu"
          class="absolute left-0 top-full hidden w-full origin-top border-b border-gray-100 bg-white p-6 shadow-2xl animate-fade-in-up md:hidden"
        >
          <nav class="flex flex-col space-y-4 font-display text-2xl font-bold">
            {
              navLinks.map((link) => {
                const active = isActiveLink(link.href);

                return (
                  <a
                    href={link.href}
                    class:list={[
                      "transition-colors hover:text-brand-lime",
                      active && "text-brand-lime",
                    ]}
                    aria-current={active ? "page" : undefined}
                  >
                    {link.label}
                  </a>
                );
              })
            }
          </nav>
        </div>
      </header>

      <div class="flex-1 pt-20">
        <slot />
      </div>

      <footer class="border-t border-gray-200 bg-gray-50 py-12">
        <div
          class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-8 px-6 md:flex-row"
        >
          <div class="text-center md:text-left">
            <span class="font-display text-2xl font-bold tracking-tight">Helio.dev</span>
            <p class="mt-2 text-sm text-gray-500">
              © 2024 Hélio Fernandes. Construído com lógica e criatividade.
            </p>
          </div>

          <button
            id="back-to-top"
            type="button"
            class="hover-trigger flex h-12 w-12 items-center justify-center rounded-full border border-gray-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-black hover:bg-black hover:text-brand-lime"
            aria-label="Voltar ao topo"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path d="m6 12 6-6 6 6"></path>
              <path d="M12 18V6"></path>
            </svg>
          </button>
        </div>
      </footer>
    </div>

    <script is:inline>
      const header = document.getElementById("main-header");

      if (header instanceof HTMLElement) {
        const updateHeaderState = () => {
          if (window.scrollY > 50) {
            header.classList.add("shadow-sm", "border-gray-100");
            header.classList.remove("border-transparent");
          } else {
            header.classList.remove("shadow-sm", "border-gray-100");
            header.classList.add("border-transparent");
          }
        };

        updateHeaderState();
        window.addEventListener("scroll", updateHeaderState, { passive: true });
      }

      const revealElements = Array.from(
        document.querySelectorAll(".reveal-on-scroll"),
      );

      if (revealElements.length > 0) {
        if ("IntersectionObserver" in window) {
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-visible");
                  observer.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
          );

          revealElements.forEach((element) => observer.observe(element));
        } else {
          revealElements.forEach((element) =>
            element.classList.add("is-visible"),
          );
        }
      }

      const mobileMenu = document.getElementById("mobile-menu");
      const mobileMenuButton = document.getElementById("mobile-menu-button");

      if (
        mobileMenu instanceof HTMLElement &&
        mobileMenuButton instanceof HTMLButtonElement
      ) {
        mobileMenuButton.addEventListener("click", () => {
          const isHidden = mobileMenu.classList.toggle("hidden");
          mobileMenuButton.setAttribute("aria-expanded", String(!isHidden));
        });

        mobileMenu.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            mobileMenu.classList.add("hidden");
            mobileMenuButton.setAttribute("aria-expanded", "false");
          });
        });
      }

      const backToTopButton = document.getElementById("back-to-top");

      if (backToTopButton instanceof HTMLButtonElement) {
        backToTopButton.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    </script>
  </body>
</html>
