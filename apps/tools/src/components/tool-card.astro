---
import TagChip from '@/components/tag-chip.astro';
import { getFaviconUrl } from '@/lib/tool-card-utils';
import type { Tool } from '@/types/catalog';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;

const iconUrl = tool.iconUrl ?? getFaviconUrl(tool.url);
---

<article class="group relative overflow-hidden rounded-3xl border border-neutral-200 bg-white p-8 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-neutral-300 hover:shadow-lg">
  <div class="absolute right-4 top-4 h-20 w-20 rounded-full bg-[var(--color-accent-primary-a10)] opacity-0 blur-2xl transition-opacity duration-300 group-hover:opacity-100"></div>

  <a
    href={tool.url}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`Open ${tool.name} official site`}
    class="absolute inset-0 z-10 rounded-3xl focus-visible:outline-none"
  ></a>

  <div class="relative z-0 flex items-start justify-between gap-3">
    <div class="flex items-start gap-3">
      <div class="mt-0.5 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-neutral-200 bg-neutral-50">
        {
          iconUrl ? (
            <img
              src={iconUrl}
              alt={`${tool.name} icon`}
              width={20}
              height={20}
              class="h-5 w-5 rounded-sm"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <span class="font-mono text-xs font-semibold uppercase text-neutral-600">
              {tool.name.slice(0, 2)}
            </span>
          )
        }
      </div>

      <h3 class="font-display text-xl font-semibold tracking-tight text-neutral-950">{tool.name}</h3>
    </div>

    <span class="mt-1 inline-flex items-center gap-1.5 font-mono text-xs uppercase tracking-wider text-success-700">
      <span class="pulse-accent h-2 w-2 rounded-full bg-success-500" aria-hidden="true"></span>
      Live
    </span>
  </div>

  <p class="relative z-0 mt-3 text-sm leading-relaxed text-neutral-600">{tool.description}</p>

  <ul class="relative z-0 mt-5 flex flex-wrap gap-2" aria-label="Tool tags">
    {
      tool.tags.map((tag) => (
        <li>
          <TagChip tag={tag} />
        </li>
      ))
    }
  </ul>
</article>
