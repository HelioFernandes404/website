---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { categories } from '@/data/categories';
import { getCategoryBySlug } from '@/lib/slugs';

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { slug: category.slug },
  }));
}

const { slug } = Astro.params;
const category = getCategoryBySlug(categories, slug ?? '');
const title = `${category?.name ?? slug ?? 'Category'} | Dev Toolbox`;
const categoryPath = category ? `/category/${category.slug}` : `/category/${slug ?? ''}`;
const description = category
  ? `${category.name} tools and references in Dev Toolbox.`
  : 'Category page placeholder (coming soon).';
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={categoryPath}
  currentPath={categoryPath}
>
  <div class="mx-auto flex w-full max-w-3xl px-6 py-24">
    <section class="terminal-panel w-full p-8 sm:p-10">
      <p class="font-mono text-xs uppercase tracking-widest text-neutral-500">Category</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-neutral-950">
        {category?.name ?? slug}
      </h1>
      <p class="mt-6 text-base text-neutral-600">Coming Soon.</p>
    </section>
  </div>
</BaseLayout>
