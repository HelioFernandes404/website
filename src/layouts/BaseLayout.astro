---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  currentPath?: string;
  image?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonicalPath = "/",
  currentPath = "/",
  image = "/helio_v2.png",
  jsonLd,
} = Astro.props;

const site = Astro.site ?? new URL("https://heliosuns404.com");
const canonicalUrl = new URL(canonicalPath, site).toString();
const socialImage = new URL(image, site).toString();

const navItems = [
  { label: "Index", href: "/" },
  { label: "Craft", href: "/craft" },
  { label: "Writing", href: "/blog" },
];

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="author" content="Helio Fernandes" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Helio Fernandes" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <meta name="theme-color" content="#FFFFFF" />

    {jsonLd && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(jsonLd)}
      />
    )}
  </head>
  <body>
    <div class="site-frame">
      <header class="site-header">
        <div class="shell nav-shell">
          <a href="/" class="brand-link">Helio Fernandes</a>

          <nav aria-label="Primary">
            <ul class="nav-list">
              {
                navItems.map((item) => (
                  <li>
                    <a
                      class:list={["nav-link", { active: isActive(item.href) }]}
                      href={item.href}
                      aria-current={isActive(item.href) ? "page" : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
        </div>
      </header>

      <main class="shell page-shell">
        <slot />
      </main>
    </div>
  </body>
</html>
