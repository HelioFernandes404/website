---
import '../styles/global.css';
import Footer from '@/components/footer.astro';
import Header from '@/components/header.client';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dev Toolbox',
  description = 'Curated developer tools by category for shipping products faster.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen bg-neutral-0 text-neutral-950 antialiased">
    <div class="noise-film" aria-hidden="true"></div>
    <Header client:load />
    <main>
      <slot />
    </main>
    <a
      href="https://hub.heliosuns404.com"
      class="fixed bottom-4 right-4 z-40 rounded-full border border-neutral-900 bg-neutral-950 px-4 py-2 text-sm font-semibold text-neutral-0 shadow-lg transition hover:-translate-y-0.5 hover:bg-neutral-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-950"
      aria-label="Go to Hub page"
    >
      Next: Hub
    </a>
    <Footer />
  </body>
</html>
