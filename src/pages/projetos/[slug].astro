---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
    const projects = await getCollection("projects");

    return projects.map((project) => ({
        params: { slug: project.slug },
        props: { project },
    }));
}

interface Props {
    project: CollectionEntry<"projects">;
}

const { project } = Astro.props as Props;
const { Content } = await project.render();

const title = `${project.data.title} | Projetos`;
const description = project.data.description;
const ogImage = "/og-image.webp";
const canonicalUrl = `https://heliosuns404.com/projetos/${project.slug}/`;
---

<Layout
    title={title}
    description={description}
    ogImage={ogImage}
    canonicalUrl={canonicalUrl}
>
    <main class="min-h-screen">
        <section class="border-b border-gray-100 bg-gray-50/70">
            <div class="mx-auto max-w-3xl px-6 py-16 md:py-20">
                <p class="font-mono text-sm uppercase tracking-wider text-brand-gray">
                    Projeto
                </p>
                <h1 class="mt-3 text-4xl font-display font-bold tracking-tight lg:text-5xl">
                    {project.data.title}
                </h1>
                <p class="mt-4 text-lg text-gray-600">{project.data.description}</p>
                <p class="mt-6 font-mono text-xs uppercase tracking-wide text-gray-500">
                    {project.data.tech.join(" • ")}
                </p>
                {
                    project.data.url && (
                        <p class="mt-6">
                            <a
                                href={project.data.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="hover-trigger inline-flex items-center gap-2 rounded-lg bg-black px-5 py-2.5 font-medium text-white transition-all duration-300 hover:bg-brand-lime hover:text-black"
                            >
                                Acessar projeto
                                <span aria-hidden="true">-></span>
                            </a>
                        </p>
                    )
                }
            </div>
        </section>

        <section class="mx-auto max-w-3xl px-6 py-16 md:py-20">
            <article class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm md:p-10">
                <Content />
            </article>

            <a
                href="/projetos/"
                class="hover-trigger mt-8 inline-flex items-center gap-2 rounded-lg border border-gray-200 px-5 py-2.5 font-medium transition-all duration-300 hover:border-brand-lime hover:bg-gray-50"
            >
                Voltar para projetos
                <span aria-hidden="true">&lt;-</span>
            </a>
        </section>
    </main>
</Layout>
