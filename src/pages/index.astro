---
import LinkIcon from "../components/LinkIcon.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import profile from "../data/profile.json";

const description = profile.bio.replace(/\n/g, " ").trim();
const primaryUrl =
  profile.links.find((link) => link.primary)?.url ?? "https://heliosuns404.com";
const mailUrl = profile.links.find((link) => link.url.startsWith("mailto:"))?.url;
const sameAs = profile.links
  .map((link) => link.url)
  .filter((url) => /^https?:\/\//.test(url));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: profile.role,
  description,
  image: profile.image,
  url: primaryUrl,
  sameAs,
  ...(mailUrl
    ? {
        contactPoint: [
          {
            "@type": "ContactPoint",
            contactType: "professional",
            email: mailUrl.replace("mailto:", ""),
          },
        ],
      }
    : {}),
};
---

<BaseLayout
  title={`${profile.name} | ${profile.role}`}
  description={description}
  image={profile.image}
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <div class="page">
    <div class="grid-pattern" aria-hidden="true"></div>
    <div class="overlay" aria-hidden="true"></div>
    <div class="glow" aria-hidden="true"></div>

    <main class="content">
      <article class="card">
        <div class="accent-line" aria-hidden="true"></div>
        <header class="profile-header">
          <img
            src={profile.image}
            width="128"
            height="128"
            alt={`Portrait of ${profile.name}`}
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
          <h1>{profile.name}</h1>
          <p class="role">{profile.role}</p>
          <p class="bio">{profile.bio}</p>
        </header>

        <hr />

        <section aria-label="Social and contact links" class="links">
          {
            profile.links.map((link) => {
              const isExternal = /^https?:\/\//.test(link.url);

              return (
                <a
                  class:list={["link-item", { primary: Boolean(link.primary) }]}
                  href={link.url}
                  target={isExternal ? "_blank" : undefined}
                  rel={isExternal ? "noopener noreferrer" : undefined}
                  aria-label={`${link.label} profile`}
                >
                  <span class="left-group">
                    <span class="icon-wrap" aria-hidden="true">
                      <LinkIcon name={link.iconName} />
                    </span>
                    <span>{link.label}</span>
                  </span>
                  <span class="arrow" aria-hidden="true">→</span>
                </a>
              );
            })
          }
        </section>
      </article>

      <footer>
        <p>Built with Astro for fast rendering and SEO-first delivery.</p>
      </footer>
    </main>
  </div>
</BaseLayout>
