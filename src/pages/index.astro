---
import LinkIcon from "../components/LinkIcon.astro";
import { posts } from "../data/posts";
import profile from "../data/profile.json";
import BaseLayout from "../layouts/BaseLayout.astro";

const description = profile.bio.replace(/\n/g, " ").trim();
const site = Astro.site ?? new URL("https://hub.heliosuns404.com");
const homeUrl = new URL("/", site).toString();
const imageUrl = new URL(profile.image, site).toString();
const bioParagraphs = profile.bio
  .split("\n")
  .map((paragraph) => paragraph.trim())
  .filter(Boolean);

if (bioParagraphs.length < 2) {
  bioParagraphs.push("I build practical systems with strong operations and measurable outcomes.");
}

const mailUrl = profile.links.find((link) => link.url.startsWith("mailto:"))?.url;
const sameAs = profile.links
  .map((link) => link.url)
  .filter((url) => /^https?:\/\//.test(url));

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${homeUrl}#person`,
  name: profile.name,
  jobTitle: profile.role,
  description,
  image: imageUrl,
  url: homeUrl,
  sameAs,
  mainEntityOfPage: homeUrl,
  ...(mailUrl
    ? {
        contactPoint: [
          {
            "@type": "ContactPoint",
            contactType: "professional",
            email: mailUrl.replace("mailto:", ""),
          },
        ],
      }
    : {}),
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${homeUrl}#website`,
  name: profile.name,
  url: homeUrl,
  description,
  inLanguage: "en",
  publisher: { "@id": `${homeUrl}#person` },
};

const jsonLd = [websiteJsonLd, personJsonLd];

type ProfileLink = (typeof profile.links)[number];

const getLinkMeta = (link: ProfileLink) => {
  if (link.url.startsWith("mailto:")) {
    return {
      tag: "Contact",
      projectDescription: "Direct communication for freelance and collaboration opportunities.",
      resourceDescription: "Email channel for proposals, consulting and project discussions.",
    };
  }

  if (/github/i.test(link.label)) {
    return {
      tag: "Code",
      projectDescription: "Code repositories, experiments and automation work.",
      resourceDescription: "Technical references and implementation details.",
    };
  }

  if (/linkedin/i.test(link.label)) {
    return {
      tag: "Network",
      projectDescription: "Professional network and long-form career timeline.",
      resourceDescription: "Background, experience and professional updates.",
    };
  }

  if (link.primary || /portfolio/i.test(link.label)) {
    return {
      tag: "Project",
      projectDescription: "Main portfolio with selected projects and service overview.",
      resourceDescription: "Primary destination with detailed project context.",
    };
  }

  return {
    tag: "Link",
    projectDescription: "Featured link connected to my development work.",
    resourceDescription: "Useful reference and profile endpoint.",
  };
};

const projectLinks = profile.links.filter(
  (link) => link.primary || /portfolio|github/i.test(link.label)
);
const projects = projectLinks.length > 0 ? projectLinks : profile.links.slice(0, 2);
const projectIds = new Set(projects.map((link) => link.id));
const resources = profile.links.filter((link) => !projectIds.has(link.id));

const featuredPost = [...posts].sort((a, b) => b.date.localeCompare(a.date))[0];
---

<BaseLayout
  title={`${profile.name} | Software Engineer, DevOps and AI in Production`}
  description={description}
  image={profile.image}
  imageAlt={`${profile.name} profile photo`}
  canonicalPath="/"
  currentPath="/"
  jsonLd={jsonLd}
>
  <section class="intro-block">
    <h1>{profile.name}</h1>
    <p class="intro-subtitle">{profile.role}</p>
    {
      bioParagraphs.map((paragraph) => (
        <p class="intro-paragraph">{paragraph}</p>
      ))
    }
  </section>

  <section class="content-block">
    <h2>Projects</h2>
    <ul class="entry-list">
      {
        projects.map((link) => {
          const isExternal = /^https?:\/\//.test(link.url);
          const meta = getLinkMeta(link);

          return (
            <li>
              <a
                class="entry-link"
                href={link.url}
                target={isExternal ? "_blank" : undefined}
                rel={isExternal ? "noopener noreferrer" : undefined}
              >
                <span class="entry-top">
                  <span class="entry-title-wrap">
                    <span class="icon-wrap" aria-hidden="true">
                      <LinkIcon name={link.iconName} />
                    </span>
                    <span class="entry-title">{link.label}</span>
                  </span>
                  <span class="entry-tag">{meta.tag}</span>
                </span>
                <span class="entry-description">{meta.projectDescription}</span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>

  {resources.length > 0 && (
    <section class="content-block">
      <h2>Resources</h2>
      <ul class="entry-list">
        {
          resources.map((link) => {
            const isExternal = /^https?:\/\//.test(link.url);
            const meta = getLinkMeta(link);

            return (
              <li>
                <a
                  class="entry-link"
                  href={link.url}
                  target={isExternal ? "_blank" : undefined}
                  rel={isExternal ? "noopener noreferrer" : undefined}
                >
                  <span class="entry-top">
                    <span class="entry-title-wrap">
                      <span class="icon-wrap" aria-hidden="true">
                        <LinkIcon name={link.iconName} />
                      </span>
                      <span class="entry-title">{link.label}</span>
                    </span>
                    <span class="entry-tag">{meta.tag}</span>
                  </span>
                  <span class="entry-description">{meta.resourceDescription}</span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </section>
  )}

  {featuredPost && (
    <section class="content-block">
      <h2>Writing</h2>

      <a class="entry-link" href={`/blog/${featuredPost.slug}`}>
        <span class="entry-top">
          <span class="entry-title-wrap">
            <span class="entry-title">{featuredPost.title}</span>
          </span>
          <span class="entry-tag">{featuredPost.category}</span>
        </span>
        <span class="entry-description">{featuredPost.description}</span>
        <span class="entry-meta">
          <time datetime={featuredPost.date}>{featuredPost.date}</time> • {featuredPost.category}
        </span>
      </a>

      <a class="text-link" href="/blog">View all posts → Blog</a>
    </section>
  )}
</BaseLayout>
