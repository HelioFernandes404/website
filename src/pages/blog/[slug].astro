---
import type { BlogPost } from "../../data/posts";
import { posts } from "../../data/posts";
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Props {
  post: BlogPost;
}

export function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as Props;
---

<BaseLayout
  title={`${post.title} | Helio Fernandes`}
  description={post.description}
  canonicalPath={`/blog/${post.slug}`}
  currentPath="/blog"
>
  <article class="post-layout">
    <a class="text-link" href="/blog">← Back to blog</a>

    <header class="post-header">
      <h1>{post.title}</h1>
      <p class="entry-meta">{post.date}</p>
      <p class="intro-paragraph">{post.lead}</p>
    </header>

    {
      post.sections.map((section) => (
        <section class="post-section">
          <h2>{section.heading}</h2>

          {section.paragraphs.map((paragraph) => <p class="intro-paragraph">{paragraph}</p>)}

          {section.bullets && (
            <ul class="post-bullets">
              {section.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          )}

          {section.tips?.map((tip) => (
            <div class="tip-box">
              <span class="tip-label">Tip</span>
              <p>{tip}</p>
            </div>
          ))}
        </section>
      ))
    }

    <section class="post-section">
      <h2>Checklist final</h2>
      <ul class="post-bullets">
        {post.checklist.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="post-section">
      <h2>Erros comuns</h2>
      <ul class="post-bullets">
        {post.commonErrors.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="post-section">
      <h2>Keywords</h2>
      <ul class="keyword-list">
        {post.keywords.map((keyword) => <li class="keyword-chip">{keyword}</li>)}
      </ul>
    </section>
  </article>
</BaseLayout>
